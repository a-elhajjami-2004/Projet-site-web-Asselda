{
	"name": "asselda-project",
	"version": "0.1.0",
	"private": true,
	"description": "Site web de l'association Asselda - Frontend + Backend (Strapi)",
	"workspaces": [
		"apps/frontend",
		"apps/backend"
	],
	"scripts": {
		"dev": "concurrently \"npm run dev --workspace=apps/frontend\" \"npm run dev --workspace=apps/backend\"",
		"build": "npm run build --workspace=apps/frontend && npm run build --workspace=apps/backend",
		"start": "concurrently \"npm run start --workspace=apps/frontend\" \"npm run start --workspace=apps/backend\"",
		"frontend:dev": "npm run dev --workspace=apps/frontend",
		"frontend:build": "npm run build --workspace=apps/frontend",
		"backend:dev": "npm run dev --workspace=apps/backend",
		"backend:build": "npm run build --workspace=apps/backend"
	},
	"devDependencies": {
		"@types/negotiator": "^0.6.4",
		"concurrently": "^9.0.1"
	}
}
