{
	"kind": "collectionType",
	"collectionName": "events",
	"info": {
		"singularName": "event",
		"pluralName": "events",
		"displayName": "Événement",
		"description": "Événements et activités"
	},
	"options": {
		"increments": true,
		"timestamps": true,
		"draftAndPublish": true
	},
	"pluginOptions": {},
	"attributes": {
		"titleFr": {
			"type": "string",
			"required": true,
			"unique": false,
			"pluginOptions": {}
		},
		"titleAr": {
			"type": "string",
			"required": true,
			"unique": false,
			"pluginOptions": {}
		},
		"descriptionFr": {
			"type": "richtext",
			"required": true,
			"pluginOptions": {}
		},
		"descriptionAr": {
			"type": "richtext",
			"required": true,
			"pluginOptions": {}
		},
		"date": {
			"type": "datetime",
			"required": true,
			"pluginOptions": {}
		},
		"location": {
			"type": "string",
			"required": false,
			"pluginOptions": {}
		},
		"image": {
			"type": "media",
			"multiple": false,
			"required": false,
			"allowedTypes": ["images"],
			"pluginOptions": {}
		},
		"status": {
			"type": "enumeration",
			"enum": ["Programmé", "En cours", "Terminé", "Annulé"],
			"default": "Programmé",
			"pluginOptions": {}
		},
		"slug": {
			"type": "uid",
			"targetField": "titleFr",
			"required": false,
			"pluginOptions": {}
		}
